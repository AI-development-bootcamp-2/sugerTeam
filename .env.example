# "development" | "production" | "test"
NODE_ENV=development

# Prisma — PostgreSQL 15 connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/time_reporting

# JWT — use long random strings in production; access and refresh must differ
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=30d

# Multer — absence document storage (path relative to backend/, created on first upload)
UPLOAD_DIR=./uploads/absence-docs

# Express server port (Docker maps this to the host)
PORT=3000

# Axios base URL + Express CORS origin — set to deployed API URL in production
VITE_API_URL=http://localhost:3000
